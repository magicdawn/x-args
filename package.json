{
  "name": "@magicdawn/x-args",
  "type": "module",
  "version": "3.2.1",
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "description": "play with cli commands like a composer",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/x-args#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/x-args.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/x-args/issues"
  },
  "keywords": [
    "x-args",
    "xargs",
    "args-composer",
    "args-manipulator"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "x-args": "./dist/bin.js",
    "x-args-bun": "./exe/x-args-bun"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "bin": {
      "x-args": "./dist/bin.js"
    }
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src",
    "check": "conc pnpm:lint pnpm:typecheck",
    "build": "pnpm check && tsdown",
    "prepublishOnly": "pnpm run build",
    "test": "mocha",
    "test-cover": "nyc --reporter=lcov --reporter=text mocha",
    "report-cover": "codecov",
    "build:watch": "rm -rf lib; tsgo -d -w",
    "build:bun-exe": "bun build --format esm --compile --bytecode --minify --sourcemap --outfile ./exe/x-args-bun ./src/bin.ts && rm -f ./.*.bun-build"
  },
  "peerDependencies": {
    "clipanion": "^4.0.0-rc.4"
  },
  "dependencies": {
    "better-result": "^2.9.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "emittery": "^2.0.0",
    "env-paths": "^4.0.0",
    "es-toolkit": "^1.49.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.6",
    "log-symbols": "^7.0.1",
    "mac-helper": "^0.10.0",
    "ms": "^2.1.3",
    "needle-kit": "^3.8.0",
    "obug": "^2.1.3",
    "p-queue": "^9.3.1",
    "proper-lockfile": "^4.1.2",
    "shlex": "^3.0.0",
    "siginfo": "^2.0.0",
    "superjson": "^2.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@magicdawn/eslint-config": "^1.6.11",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/ms": "^2.1.0",
    "@types/node": "^26.1.1",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "concurrently": "^10.0.3",
    "eslint": "10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mocha": "11.7.6",
    "nyc": "18.0.0",
    "prettier": "^3.9.4",
    "should": "^13.2.3",
    "tsdown": "^0.22.4",
    "type-fest": "^5.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts,jsx,tsx,json,md,yaml,yml}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
