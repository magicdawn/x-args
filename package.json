{
  "name": "@magicdawn/x-args",
  "type": "module",
  "version": "3.1.1",
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "description": "play with cli commands like a composer",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/x-args#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/x-args.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/x-args/issues"
  },
  "keywords": [
    "x-args",
    "xargs",
    "args-composer",
    "args-manipulator"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "x-args": "./dist/bin.js",
    "x-args-js": "./dist/bin.js",
    "x-args-bun": "./exe/x-args-bun"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src",
    "check": "conc pnpm:lint pnpm:typecheck",
    "build": "pnpm check && tsdown",
    "prepublishOnly": "pnpm run build",
    "test": "mocha",
    "test-cover": "nyc --reporter=lcov --reporter=text mocha",
    "report-cover": "codecov",
    "build:watch": "rm -rf lib; tsgo -d -w",
    "build:bun-exe": "bun build --format esm --compile --bytecode --minify --sourcemap --outfile ./exe/x-args-bun ./src/bin.ts && rm -f ./.*.bun-build"
  },
  "peerDependencies": {
    "clipanion": "^4.0.0-rc.4"
  },
  "dependencies": {
    "@optique/core": "^1.0.2",
    "@optique/discover": "^1.1.0",
    "@optique/run": "^1.1.0",
    "better-result": "^2.9.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "emittery": "^2.0.0",
    "env-paths": "^4.0.0",
    "es-toolkit": "^1.47.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "log-symbols": "^7.0.1",
    "mac-helper": "^0.9.0",
    "ms": "^2.1.3",
    "needle-kit": "^3.8.0",
    "obug": "^2.1.2",
    "p-queue": "^9.3.0",
    "proper-lockfile": "^4.1.2",
    "shlex": "^3.0.0",
    "siginfo": "^2.0.0",
    "superjson": "^2.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@magicdawn/eslint-config": "^1.6.6",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript/native-preview": "7.0.0-dev.20260610.1",
    "concurrently": "^9.2.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "11.7.6",
    "nyc": "18.0.0",
    "prettier": "^3.8.4",
    "should": "^13.2.3",
    "tsdown": "^0.22.2",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts,jsx,tsx,json,md,yaml,yml}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
